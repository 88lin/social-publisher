{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(sleep *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(test *)"
    ],
    "deny": [
      "Write(publishers/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-publish-check.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/post-publish-verify.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
